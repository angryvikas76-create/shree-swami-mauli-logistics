# ==========================
# SERVER CONFIGURATION
# ==========================
PORT=5000
NODE_ENV=development

# ==========================
# MONGODB
# ==========================
MONGO_URI=mongodb://localhost:27017/ssm_logistics

# Example for MongoDB Atlas
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ssm_logistics

# ==========================
# JWT
# ==========================
JWT_SECRET=ChangeThisToAVeryLongRandomSecretKey
JWT_EXPIRES_IN=7d

# ==========================
# ADMIN ACCOUNT
# ==========================
ADMIN_EMAIL=admin@ssmlogistics.com
ADMIN_PASSWORD=admin123

# ==========================
# EMAIL (Optional)
# ==========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ==========================
# FILE UPLOAD
# ==========================
UPLOAD_PATH=uploads

# ==========================
# QR CODE
# ==========================
QR_BASE_URL=http://localhost:5000/track/
